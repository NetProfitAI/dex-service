{
  "name": "dex-service",
  "version": "1.0.0",
  "description": "Solana DEX price service – supports Raydium, Whirlpool (Orca) and Meteora",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "keywords": [
    "solana",
    "dex",
    "raydium",
    "orca",
    "whirlpool",
    "meteora",
    "defi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@meteora-ag/dlmm": "^1.9.3",
    "@orca-so/whirlpools": "^7.0.1",
    "@raydium-io/raydium-sdk-v2": "^0.2.32-alpha",
    "@solana/addresses": "^6.3.1",
    "@solana/kit": "^5.5.1",
    "@solana/rpc": "^5.5.1",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.13.6",
    "bn.js": "^5.2.1",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
